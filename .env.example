# ─── gRPC addresses ───────────────────────────────────────────────────────────
ENGINE_GRPC_ADDRESS=localhost:50051
RAG_GRPC_ADDRESS=localhost:50052

# ─── Gateway ──────────────────────────────────────────────────────────────────
# URL the browser uses to open the WebSocket connection.
GATEWAY_WS_URL=ws://localhost:8000/ws

# ─── AI / Vector Store ────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=agentpredict

# ─── BallDontLie MMA API ─────────────────────────────────────────────────────
# Free tier: event discovery only.
# GOAT tier ($39.99/mo): fight stats — required to unlock live stat polling.
BALLDONTLIE_API_KEY=your_balldontlie_api_key_here

# ─── Optional dev flags ───────────────────────────────────────────────────────
# Set to "1" to dump raw API responses to /tmp/ for debugging.
DEBUG_DUMP=0

# Minimum probability delta to emit a Polymarket event.
POLYMARKET_DELTA_THRESHOLD=0.01

# Poll interval in seconds for each agent.
POLYMARKET_POLL_INTERVAL_S=5
MMA_POLL_INTERVAL_S=30
